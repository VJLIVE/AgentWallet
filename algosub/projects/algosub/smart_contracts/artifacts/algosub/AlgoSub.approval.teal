    app_local_get_ex
    assert // check self.max_amount exists for account
    // smart_contracts/algosub/contract.py:47-48
    // # Get the payment transaction (index 1)
    // payment_txn = gtxn.PaymentTransaction(1)
    intc_0 // 1
    // smart_contracts/algosub/contract.py:59-60
    // # Validate amount
    // assert payment_txn.amount <= user_max_amount, "Payment exceeds max amount"
    gtxns Amount
    >=
    assert // Payment exceeds max amount
    // smart_contracts/algosub/contract.py:36
    // @arc4.abimethod
    pushbytes 0x151f7c75001e5061796d656e742076616c696461746564207375636365737366756c6c79
    log
    intc_0 // 1
    return
