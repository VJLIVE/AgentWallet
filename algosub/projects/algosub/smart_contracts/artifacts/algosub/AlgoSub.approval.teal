#pragma version 11
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    intcblock 1 0 2
    bytecblock "max_amount"
    txn ApplicationID
    bnz main_after_if_else@2
    // smart_contracts/algosub/contract.py:11-12
    // # Store admin on creation
    // self.admin = Txn.sender
    pushbytes "admin"
    txn Sender
    app_global_put

main_after_if_else@2:
    // smart_contracts/algosub/contract.py:4
    // class AlgoSub(ARC4Contract):
    txn NumAppArgs
    bz main___algopy_default_create@13
    pushbytes 0x30c6d58a // method "opt_in()void"
    txna ApplicationArgs 0
    match main_opt_in_route@5
    txn OnCompletion
    !
    assert
    txn ApplicationID
    assert
    pushbytess 0xfc83b408 0xafea3a83 // method "set_rule(string,uint64)void", method "validate_payment()string"
    txna ApplicationArgs 0
    match set_rule validate_payment
    err

main_opt_in_route@5:
    // smart_contracts/algosub/contract.py:17
    // @arc4.abimethod(allow_actions=["OptIn"])
    txn OnCompletion
    intc_0 // OptIn
    ==
    txn ApplicationID
    &&
    return

main___algopy_default_create@13:
    txn OnCompletion
    !
    txn ApplicationID
    !
    &&
    return


// smart_contracts.algosub.contract.AlgoSub.set_rule[routing]() -> void:
set_rule:
    // smart_contracts/algosub/contract.py:24
    // @arc4.abimethod
    txna ApplicationArgs 1
    dup
    intc_1 // 0
    extract_uint16 // on error: invalid array length header
    intc_2 // 2
    +
    dig 1
    len
    ==
    assert // invalid number of bytes for arc4.dynamic_array<arc4.uint8>
    extract 2 0
    txna ApplicationArgs 2
    dup
    len
    pushint 8
    ==
    assert // invalid number of bytes for arc4.uint64
    btoi
    // smart_contracts/algosub/contract.py:32-33
    // # Store rule in caller's local state
    // self.vendor[Txn.sender] = vendor
    txn Sender
    pushbytes "vendor"
    uncover 3
    app_local_put
    // smart_contracts/algosub/contract.py:34
    // self.max_amount[Txn.sender] = max_amount
    txn Sender
    bytec_0 // "max_amount"
    uncover 2
    app_local_put
    // smart_contracts/algosub/contract.py:24
    // @arc4.abimethod
    intc_0 // 1
    return


// smart_contracts.algosub.contract.AlgoSub.validate_payment[routing]() -> void:
validate_payment:
    // smart_contracts/algosub/contract.py:44-45
    // # Ensure this is a grouped transaction with 2 txns
    // assert Global.group_size == 2, "Must be grouped with payment"
    global GroupSize
    intc_2 // 2
    ==
    assert // Must be grouped with payment
    // smart_contracts/algosub/contract.py:47-48
    // # Get the payment transaction (index 1)
    // payment_txn = gtxn.PaymentTransaction(1)
    intc_0 // 1
    gtxns TypeEnum
    intc_0 // pay
    ==
    assert // transaction type is pay
    intc_0 // 1
    // smart_contracts/algosub/contract.py:53-54
    // # Verify sender matches
    // assert payment_txn.sender == Txn.sender, "Payment sender must match caller"
    gtxns Sender
    txn Sender
    ==
    assert // Payment sender must match caller
    // smart_contracts/algosub/contract.py:56-57
    // # Get user's max amount rule
    // user_max_amount = self.max_amount[Txn.sender]
    txn Sender
    intc_1 // 0
